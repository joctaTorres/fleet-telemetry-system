{
  "uid": "cdc-consumer",
  "title": "CDC Consumer",
  "tags": ["fleet", "cdc", "otel", "pubsub"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CDC event throughput by type",
      "description": "Per-second rate of WAL change events the consumer decoded and published onto the fleet:events channel, from the cdc.events_published counter (cdc_events_published_total), broken down by cdc.event_type so vehicle_state_changed / zone_count_changed / anomaly_detected are each visible.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "events/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (cdc_event_type) (rate(cdc_events_published_total[$__rate_interval]))",
          "legendFormat": "{{cdc_event_type}}",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Total publish rate",
      "description": "Fleet-wide per-second publish rate across all event types from cdc_events_published_total — the headline throughput of the CDC consumer.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 0.001 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(cdc_events_published_total[$__rate_interval]))",
          "legendFormat": "events/sec",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Decode lag (p95 / p50)",
      "description": "WAL-decode latency quantiles via histogram_quantile over cdc_decode_lag_milliseconds_bucket (unit: ms), the buckets derived from the cdc.decode.lag histogram. Measures how far behind the logical-replication stream the consumer is running.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "decode lag (ms)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cdc_decode_lag_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cdc_decode_lag_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Decode lag p95 by event type",
      "description": "Decode-lag p95 split by cdc.event_type so a lagging change category is isolatable. histogram_quantile over cdc_decode_lag_milliseconds_bucket grouped by le and cdc_event_type.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "decode lag (ms)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, cdc_event_type) (rate(cdc_decode_lag_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95 {{cdc_event_type}}",
          "range": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Recent cdc-consumer traces",
      "description": "Recent service.name=cdc-consumer traces from Tempo. Click a Trace ID to drill into the cdc.decode (WAL decode) and per-event cdc.publish spans.",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "scope": "resource",
              "operator": "=",
              "value": ["cdc-consumer"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "tableType": "traces",
          "query": "{ resource.service.name = \"cdc-consumer\" }"
        }
      ]
    }
  ]
}
