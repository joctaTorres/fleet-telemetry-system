      "includeVars": false
    },
    {
      "title": "Frontend API & WebSockets",
      "type": "link",
      "url": "/d/frontend-api",
      "icon": "external link",
      "tooltip": "REST + WebSocket frontend flow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "CDC Consumer",
      "type": "link",
      "url": "/d/cdc-consumer",
      "icon": "external link",
      "tooltip": "Change-data-capture publish flow",
      "targetBlank": false,
