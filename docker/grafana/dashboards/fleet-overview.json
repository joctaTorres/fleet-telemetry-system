      "includeVars": false
    },
    {
      "title": "Pub/Sub",
      "type": "link",
      "url": "/d/pubsub",
      "icon": "external link",
      "tooltip": "Redis pub/sub fleet:events flow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "Redis Fan-out",
      "type": "link",
      "url": "/d/redis-fan-out",
      "icon": "external link",
      "tooltip": "WebSocket fan-out delivery flow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "Primary/Replica Streaming",
      "type": "link",
      "url": "/d/primary-replica-streaming",
      "icon": "external link",
      "tooltip": "Postgres streaming replication flow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    },
    {
      "title": "Frontend Web (Browser)",
      "type": "link",
      "url": "/d/frontend-web-browser",
      "icon": "external link",
      "tooltip": "Browser RUM (SPA) flow",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": false
    }
  ],
  "panels": [
    {
      "id": 1,
      "title": "Ingestion throughput",
      "description": "Top-level ingress health: per-second POST /telemetry request rate across all routes, from sum(rate(ingestion_requests_total)). This is the head of the pipeline driven by the k6 50-vehicle fleet. Drill into the Ingestion API dashboard for per-route / error breakdown.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(ingestion_requests_total[$__rate_interval]))",
          "legendFormat": "ingestion req/s",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Ingestion errors",
      "description": "Top-level error signal: per-second rate of non-2xx ingestion responses, from sum(rate(ingestion_requests_total{http_status_code!~\"2..\"})). Stays green at zero; turns red if the ingestion edge starts rejecting. Drill into Ingestion API for the status-code/route breakdown.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.1
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(ingestion_requests_total{http_status_code!~\"2..\"}[$__rate_interval]))",
          "legendFormat": "errors/s",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "WebSocket connections",
      "description": "Live fan-out reach: current active WebSocket connections on the frontend, from max(frontend_ws_active_connections). The number of browser dashboards currently receiving real-time pushes. Drill into Frontend API & WebSockets or Redis Fan-out.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(frontend_ws_active_connections)",
          "legendFormat": "connections",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "title": "CDC publish rate",
      "description": "Change-data-capture health: per-second rate of events the CDC consumer publishes to Redis fleet:events, from sum(rate(cdc_events_published_total)). The bridge between the database WAL and the real-time fan-out. Drill into CDC Consumer or Pub/Sub.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(cdc_events_published_total[$__rate_interval]))",
          "legendFormat": "events/s",
          "range": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Redis fan-out rate",
      "description": "Egress health: per-second rate of WebSocket broadcasts the frontend fans out to connected clients, from sum(rate(frontend_ws_broadcasts_total)). The tail of the pipeline that delivers each CDC event to every browser. Drill into Redis Fan-out.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(frontend_ws_broadcasts_total[$__rate_interval]))",
          "legendFormat": "broadcasts/s",
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Replication lag",
      "description": "Database streaming health: wall-clock seconds the replica trails the primary, from max(pg_replication_lag_seconds). Green near zero; the frontend reads (e.g. zone counts) are served from this standby. Drill into Primary/Replica Streaming.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(pg_replication_lag_seconds)",
          "legendFormat": "lag (s)",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 7,
      "title": "Critical-flow service graph",
      "description": "Tempo-generated service graph of all critical flows, rendered from the Prometheus traces_service_graph_* series (the Tempo datasource's service map is bound to Prometheus by uid). Shows the connected critical-flow edges built from real trace data: user -> ingestion-api -> db (ingest + WAL write), cdc-consumer -> frontend-api (CDC across Redis pub/sub), frontend-api -> replica (replica reads), and user/browser -> frontend-api (REST + WebSocket). Each edge's stats come from traces_service_graph_request_total and the request-duration histograms.",
      "type": "nodeGraph",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "nodes": {
          "mainStatUnit": "ms"
        },
        "edges": {}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "serviceMap"
        }
      ]
    },
    {
      "id": 8,
      "title": "End-to-end pipeline throughput",
      "description": "The whole real-time pipeline on one axis: ingestion ingress (ingestion_requests_total), CDC publishes to Redis (cdc_events_published_total), and WebSocket fan-out to browsers (frontend_ws_broadcasts_total). When the stack is healthy all three track the k6-driven load together, ingress -> CDC -> fan-out.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "events/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(ingestion_requests_total[$__rate_interval]))",
          "legendFormat": "ingestion ingress",
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(cdc_events_published_total[$__rate_interval]))",
          "legendFormat": "CDC publish",
          "range": true
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(frontend_ws_broadcasts_total[$__rate_interval]))",
          "legendFormat": "WS fan-out",
          "range": true
        }
      ]
    },
    {
      "id": 9,
      "title": "API latency p95 (ingestion vs frontend)",
      "description": "Cross-tier latency: p95 over ingestion_request_duration_milliseconds_bucket and frontend_request_duration_milliseconds_bucket. At-a-glance comparison of the two HTTP edges; drill into the per-flow dashboards for p50 and per-route detail.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "latency (ms)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ingestion_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "ingestion p95",
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(frontend_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "frontend p95",
          "range": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Replication lag over time",
      "description": "Streaming replication trend: seconds lag from max(pg_replication_lag_seconds). The frontend's zone-count reads are served from the replica, so this is the freshness bound on those reads. Drill into Primary/Replica Streaming for byte lag per standby.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "lag (s)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(pg_replication_lag_seconds)",
          "legendFormat": "replica lag",
          "range": true
        }
      ]
    },
    {
      "id": 11,
      "title": "Recent frontend-api traces (pipeline hub)",
      "description": "Recent service.name=frontend-api traces from Tempo. frontend-api is the hub of the real-time pipeline: it parents CDC-driven broadcasts and serves browser REST/WebSocket reads, so its traces join the cdc-consumer, replica, and browser flows. Click a Trace ID to drill into a distributed trace spanning the critical flows.",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 25
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "scope": "resource",
              "operator": "=",
              "value": ["frontend-api"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "tableType": "traces",
          "query": "{ resource.service.name = \"frontend-api\" }"
        }
      ]
    }
  ]
}
