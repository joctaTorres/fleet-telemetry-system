{
  "uid": "frontend-api",
  "title": "Frontend API & WebSockets",
  "tags": ["fleet", "frontend", "websockets", "otel"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active WebSocket connections",
      "description": "Live count of connected /ws clients from the frontend.ws.active_connections gauge (frontend_ws_active_connections). The phase headline signal — non-zero whenever a dashboard SPA or WS client is connected. max() collapses the per-replica series to the fleet-wide live total.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(frontend_ws_active_connections)",
          "legendFormat": "active connections",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "REST request rate by route",
      "description": "Per-second request rate from the frontend.requests counter (frontend_requests_total), broken down by http.route so reads like GET /vehicles are visible.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "requests/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (http_route) (rate(frontend_requests_total[$__rate_interval]))",
          "legendFormat": "{{http_route}}",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "REST latency (p95 / p50)",
      "description": "Request latency quantiles via histogram_quantile over frontend_request_duration_milliseconds_bucket (unit: ms), the buckets derived from the frontend.request.duration histogram.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "latency (ms)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(frontend_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(frontend_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "REST errors (non-2xx)",
      "description": "Per-second rate of non-2xx responses isolated via the http.status_code attribute on the frontend.requests series. The 422 validation-rejection path (e.g. GET /anomalies with a bad query) populates this.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "auto",
            "lineWidth": 2,
            "axisLabel": "errors/sec",
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (http_status_code, http_route) (rate(frontend_requests_total{http_status_code!~\"2..\"}[$__rate_interval]))",
          "legendFormat": "{{http_status_code}} {{http_route}}",
          "range": true
        }
      ]
    },
    {
      "id": 5,
      "title": "WebSocket broadcast rate",
      "description": "Per-second rate of WebSocket fan-out events from the frontend.ws.broadcasts counter (frontend_ws_broadcasts_total), showing how fast updates are pushed to connected clients.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "broadcasts/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum (rate(frontend_ws_broadcasts_total[$__rate_interval]))",
          "legendFormat": "broadcasts/sec",
          "range": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent frontend-api traces",
      "description": "Recent service.name=frontend-api traces from Tempo. Click a Trace ID to drill into the GET server spans and the /ws connection-lifecycle spans.",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "scope": "resource",
              "operator": "=",
              "value": ["frontend-api"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "tableType": "traces",
          "query": "{ resource.service.name = \"frontend-api\" }"
        }
      ]
    }
  ]
}
