{
  "uid": "ingestion-api",
  "title": "Ingestion API",
  "tags": ["fleet", "ingestion", "otel"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by route",
      "description": "Per-second request rate from the ingestion.requests counter (ingestion_requests_total), broken down by http.route so the POST /telemetry flow is visible.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "requests/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (http_route) (rate(ingestion_requests_total[$__rate_interval]))",
          "legendFormat": "{{http_route}}",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Latency (p95 / p50)",
      "description": "Request latency quantiles via histogram_quantile over ingestion_request_duration_milliseconds_bucket (unit: ms).",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "latency (ms)"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ingestion_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ingestion_request_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Error rate (non-2xx)",
      "description": "Per-second rate of non-2xx responses isolated via the http.status_code attribute on the ingestion.requests series. The 422 validation-rejection path populates this.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "showPoints": "auto",
            "lineWidth": 2,
            "axisLabel": "errors/sec",
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "sum"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum by (http_status_code, http_route) (rate(ingestion_requests_total{http_status_code!~\"2..\"}[$__rate_interval]))",
          "legendFormat": "{{http_status_code}} {{http_route}}",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Recent ingestion-api traces",
      "description": "Recent service.name=ingestion-api traces from Tempo. Click a Trace ID to drill into the POST /telemetry server span.",
      "type": "table",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceqlSearch",
          "filters": [
            {
              "id": "service-name",
              "tag": "service.name",
              "scope": "resource",
              "operator": "=",
              "value": ["ingestion-api"],
              "valueType": "string"
            }
          ],
          "limit": 20,
          "tableType": "traces",
          "query": "{ resource.service.name = \"ingestion-api\" }"
        }
      ]
    }
  ]
}
