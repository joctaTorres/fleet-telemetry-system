{
  "uid": "primary-replica-streaming",
  "title": "Primary/Replica Streaming",
  "tags": ["fleet", "replication", "postgres", "otel"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Current byte lag",
      "description": "Headline WAL byte lag across all connected standbys, from max(pg_replication_lag_bytes). This is the exact series and aggregation the phase proof-of-work queries; it samples how many bytes of WAL the furthest-behind standby has not yet replayed (primary view, via pg_wal_lsn_diff over pg_stat_replication).",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1048576
              },
              {
                "color": "red",
                "value": 16777216
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(pg_replication_lag_bytes)",
          "legendFormat": "byte lag",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "title": "Current seconds lag",
      "description": "Headline time lag of the standby, from max(pg_replication_lag_seconds). Wall-clock seconds the replica's last replayed transaction trails now(), authoritative on the replica via now() - pg_last_xact_replay_timestamp().",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(pg_replication_lag_seconds)",
          "legendFormat": "seconds lag",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "Byte lag over time (per standby)",
      "description": "WAL byte lag per connected standby over time, from pg_replication_lag_bytes broken down by the application_name label so each standby (e.g. walreceiver) is a distinct series. Primary view: bytes of WAL the standby has not yet replayed.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "WAL bytes behind"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max by (application_name) (pg_replication_lag_bytes)",
          "legendFormat": "{{application_name}}",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Seconds lag over time",
      "description": "Wall-clock replication lag of the standby over time, from pg_replication_lag_seconds. Replica view: now() - pg_last_xact_replay_timestamp(), floored at 0.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "seconds behind"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(pg_replication_lag_seconds)",
          "legendFormat": "seconds lag",
          "range": true
        }
      ]
    }
  ]
}
