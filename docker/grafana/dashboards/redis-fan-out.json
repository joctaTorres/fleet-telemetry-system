{
  "uid": "redis-fan-out",
  "title": "Redis Fan-out",
  "tags": ["fleet", "redis", "websockets", "fanout", "otel"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active WebSocket connections",
      "description": "Live count of connected /ws clients receiving the Redis fan-out, from the frontend.ws.active_connections gauge (frontend_ws_active_connections). max() collapses per-replica series to the fleet-wide live total.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "text", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(frontend_ws_active_connections)",
          "legendFormat": "active connections",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Fan-out delivery rate",
      "description": "Per-second rate of WebSocket fan-out events pushed to connected clients from the frontend.ws.broadcasts counter (frontend_ws_broadcasts_total) — each fleet:events message delivered out to the /ws subscribers.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "showPoints": "never",
            "lineWidth": 2,
            "axisLabel": "broadcasts/sec"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "sum(rate(frontend_ws_broadcasts_total[$__rate_interval]))",
          "legendFormat": "broadcasts/sec",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Active connections over time",
      "description": "Trend of the frontend.ws.active_connections gauge so connects (rises) and drops (falls) are visible together with the fan-out delivery rate above.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 15,
            "showPoints": "auto",
            "lineWidth": 2,
            "axisLabel": "connections"
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max", "min"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "max(frontend_ws_active_connections)",
          "legendFormat": "active connections",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Dropped clients (best-effort)",
      "description": "Best-effort per-second rate of WebSocket disconnects, derived from downward movements in the frontend.ws.active_connections gauge — clamp_min(-deriv(...), 0). There is no dedicated dropped-client counter to bind to, so this surfaces drops in the active-connections gauge rather than inventing a new instrument; it is approximate and only registers when the gauge falls.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "fillOpacity": 25,
            "showPoints": "auto",
            "lineWidth": 2,
            "axisLabel": "drops/sec",
            "gradientMode": "opacity"
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "editorMode": "code",
          "expr": "clamp_min(-deriv(frontend_ws_active_connections[$__rate_interval]), 0)",
          "legendFormat": "dropped clients/sec (approx)",
          "range": true
        }
      ]
    }
  ]
}
